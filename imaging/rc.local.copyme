#!/bin/bash
# Copy 1 of the following contents to the end of rc.local:

# OpenCV Python
TIME="$(date +%s)"
touch /home/warg/record_$TIME.log  # To confirm script has run
cd /home/warg/model-training/
source venv/bin/activate
cd imaging/
python -m imaging

# FFmpeg video
TIME="$(date +%s)"
touch /home/warg/record_$TIME.log  # To confirm script has run
cd /home/warg/model-training/imaging/
./video.sh
